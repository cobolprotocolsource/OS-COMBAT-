# OS-COMBAT- .gitignore
# Keep repository clean and avoid committing secrets / large artifacts.

# Node
node_modules/
frontend/node_modules/

# Build outputs
dist/
build/
frontend/dist/
.vite/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
*.log

# Runtime files
pids/
*.pid
*.seed

# Environment / secrets
.env
.env.*
!.env.example

# OS files
.DS_Store
Thumbs.db

# Editors/IDE
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# Tests / coverage
coverage/
.nyc_output/
jest-report/

# Certificates and keys
*.pem
*.key
*.crt
*.p12
*.pfx

# Databases
*.sqlite
*.db
*.sqlite3

# Archives and packages
*.tgz

# Temporary
tmp/
.cache/
*.tmp
*.temp
*~

# Docker
.env.docker
docker-compose.override.yml

# Codespaces
.codespaces/

# Persisted data (audit, local DBs)
data/

# Misc
.history/
